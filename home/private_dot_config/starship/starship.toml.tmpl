format = """
{{- if .is.wsl }}
${custom.wsl}\
{{- end }}
$shell\
[оВґ](fg:#3c3c3c bg:#0c0c0c)\
$cmd_duration\
$git_status\
[оВі ](fg:#3c3c3c bg:#333333)$git_branch[оВі](bg:#1d1d1d fg:#333333)\
$fill\
[$git_commit$git_state$git_metrics](bg:#1d1d1d)\
[оГТ](fg:#1d1d1d)\
$line_break\
$jobs\
$line_break\
{{- if eq .chezmoi.os "windows" }}
$directory\
{{- end }}
$character\
"""

{{- if ne .chezmoi.os "windows" }}
right_format = """
$directory
"""
{{- end }}

{{- if .is.wsl }}
[custom.wsl]
when = "true"
symbol = "рЯРЪ"
{{- end }}

[shell]
disabled = false
fish_indicator = 'рЯРЯ'
powershell_indicator = 'рЯЪЬ'

[cmd_duration]
min_time = 400
show_milliseconds = true
style = "bg:#3c3c3c fg:#bbaabb"
format = "[ [ќФ](fg:red bg:#3c3c3c)$duration ]($style)"

[fill]
symbol = ' '
style = 'bg:#1d1d1d'

[git_status]
style = 'bg:#3c3c3c fg:#6874f2'
format = "([{[$all_status](fg:bold #32cd32 bg:#3c3c3c)$ahead_behind}]($style))"

[git_branch]
style = 'bg:#333333 fg:bold #999999'
format = '[[$symbol](bg:#333333 fg:#999999)$branch ]($style)'
truncation_length = 42

[git_metrics]
disabled = false
added_style = 'bg:#1d1d1d fg:bold green'
deleted_style = 'bg:#1d1d1d fg:bold red'

[character]
success_symbol = "[оГВоГМ](bold #32cd32)"
error_symbol = "[оАЙ](bold red)"

[directory]
truncation_symbol = "рЯУМвА¶/"
home_symbol = "рЯМ±"
