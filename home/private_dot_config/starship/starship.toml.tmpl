format = """
{{- if .is.wsl }}
${custom.wsl}\
{{- end }}
$shell\
[о‚¶](fg:#3c3c3c bg:#0c0c0c)\
$cmd_duration\
$git_status\
[о‚ґ ](fg:#3c3c3c bg:#333333)$git_branch[о‚ґ](bg:#1d1d1d fg:#333333)\
$fill\
[$git_commit$git_state$git_metrics](bg:#1d1d1d)\
[оѓ’](fg:#1d1d1d) \
$line_break\
[        ]()\
([оѓ‡](fg:#18191e)$jobs[оѓ†](fg:#18191e))\
{{- if ne .chezmoi.os "windows" }}
